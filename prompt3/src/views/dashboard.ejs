<section class="page-header">
  <h1>Dashboard</h1>
  <p class="subtitle">전체 <strong><%= pagination.total %></strong>개의 단축 URL</p>
</section>

<% if (urls.length === 0) { %>
  <section class="card empty-state">
    <p>아직 생성된 단축 URL이 없습니다.</p>
    <a href="/" class="btn btn-primary">첫 번째 URL 만들기</a>
  </section>
<% } else { %>
  <section class="card">
    <div class="table-responsive">
      <table class="url-table">
        <thead>
          <tr>
            <th>단축 URL</th>
            <th>원본 URL</th>
            <th>클릭</th>
            <th>생성일</th>
            <th>만료</th>
            <th>관리</th>
          </tr>
        </thead>
        <tbody>
          <% urls.forEach(url => { %>
            <tr>
              <td>
                <a href="<%= url.shortUrl %>" target="_blank" class="short-url-link">
                  <%= url.code %>
                </a>
              </td>
              <td class="original-url" title="<%= url.original_url %>">
                <%= url.original_url.length > 50
                    ? url.original_url.substring(0, 50) + '...'
                    : url.original_url %>
              </td>
              <td class="clicks-count"><%= url.clicks %></td>
              <td class="date-cell"><%= url.created_at.slice(0, 10) %></td>
              <td class="date-cell">
                <% if (url.expires_at) { %>
                  <% const isExpired = new Date(url.expires_at + 'Z') <= new Date(); %>
                  <span class="<%= isExpired ? 'expired-badge' : '' %>">
                    <%= url.expires_at.slice(0, 10) %>
                  </span>
                <% } else { %>
                  <span class="no-expiry">-</span>
                <% } %>
              </td>
              <td class="actions-cell">
                <a href="/dashboard/<%= url.id %>" class="btn btn-small">통계</a>
                <button
                  class="btn btn-small btn-danger delete-btn"
                  data-id="<%= url.id %>"
                >삭제</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <% if (pagination.totalPages > 1) { %>
    <nav class="pagination">
      <% if (pagination.page > 1) { %>
        <a href="/dashboard?page=<%= pagination.page - 1 %>" class="btn btn-small">&laquo; 이전</a>
      <% } %>
      <span class="page-info">
        <%= pagination.page %> / <%= pagination.totalPages %>
      </span>
      <% if (pagination.page < pagination.totalPages) { %>
        <a href="/dashboard?page=<%= pagination.page + 1 %>" class="btn btn-small">다음 &raquo;</a>
      <% } %>
    </nav>
  <% } %>
<% } %>
