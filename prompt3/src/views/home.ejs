<section class="hero">
  <h1>URL Shortener</h1>
  <p class="subtitle">긴 URL을 짧고 공유하기 쉬운 링크로 변환하세요</p>
</section>

<section class="card form-section">
  <form id="shorten-form">
    <div class="form-group">
      <label for="url">URL</label>
      <input
        type="url"
        id="url"
        name="url"
        placeholder="https://example.com/very/long/url/to/shorten"
        required
        autofocus
      >
    </div>

    <div class="form-row">
      <div class="form-group form-group-half">
        <label for="customSlug">커스텀 슬러그 <span class="optional">(선택)</span></label>
        <div class="input-prefix-group">
          <span class="input-prefix"><%= baseUrl %>/</span>
          <input
            type="text"
            id="customSlug"
            name="customSlug"
            placeholder="my-custom-url"
            pattern="[a-zA-Z0-9_-]+"
            minlength="3"
            maxlength="30"
          >
        </div>
      </div>

      <div class="form-group form-group-half">
        <label for="expiresInMinutes">만료 시간 <span class="optional">(선택)</span></label>
        <select id="expiresInMinutes" name="expiresInMinutes">
          <option value="">만료 없음</option>
          <option value="30">30분</option>
          <option value="60">1시간</option>
          <option value="1440">1일</option>
          <option value="10080">1주</option>
          <option value="43200">30일</option>
          <option value="525600">1년</option>
        </select>
      </div>
    </div>

    <button type="submit" class="btn btn-primary" id="submit-btn">
      단축 URL 생성
    </button>
  </form>
</section>

<section id="result-section" class="card result-section" style="display: none;">
  <h2>생성 완료!</h2>
  <div class="result-url-container">
    <a id="result-url" href="#" target="_blank" class="result-url"></a>
    <button id="copy-btn" class="btn btn-secondary" type="button">복사</button>
  </div>
  <p class="result-original">
    원본: <span id="result-original-url"></span>
  </p>
  <p class="result-expires" id="result-expires" style="display: none;">
    만료: <span id="result-expires-at"></span>
  </p>
</section>

<section id="error-section" class="card error-section" style="display: none;">
  <p class="error-message" id="error-message"></p>
</section>
